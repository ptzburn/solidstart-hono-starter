{
  "name": "solid-starter-template",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"deno task db:start\" \"deno task dev:app\"",
    "dev:app": "deno run --allow-env --allow-sys --allow-ffi --env-file --allow-net --allow-read --allow-write --allow-run npm:vinxi dev --port 3020",
    "build": "deno -A npm:vinxi build",
    "start": "deno run --allow-net --allow-read --allow-write --allow-ffi --allow-env --allow-sys ./.output/server/index.mjs",
    "db:start": "turso dev --db-file local.db",
    "db:generate": "deno -A --env-file npm:drizzle-kit generate",
    "db:migrate": "deno -A --env-file npm:drizzle-kit migrate",
    "db:studio": "deno -A npm:drizzle-kit studio",
    "pre-commit": "deno fmt --ignore=src/api/emails/templates ./src/ && deno lint ./src/ && deno check ./src/",
    "generate:email-types": "deno run --allow-read --allow-write src/api/emails/generate-types.ts"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.34.1",
    "@better-auth/drizzle-adapter": "^1.5.5",
    "@better-auth/passkey": "^1.5.5",
    "@corvu/calendar": "^0.1.2",
    "@corvu/drawer": "^0.2.4",
    "@corvu/otp-field": "^0.1.4",
    "@hono/zod-openapi": "^1.2.2",
    "@kobalte/core": "^0.13.11",
    "@libsql/client": "^0.17.0",
    "@scalar/hono-api-reference": "^0.10.3",
    "@seven.io/client": "^5.5.1",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.4",
    "@solidjs/start": "^1.3.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/solid-form": "^1.28.5",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk-solid": "^1.1.2",
    "concurrently": "^9.2.1",
    "drizzle-orm": "^1.0.0-beta.17-67b1795",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-solid": "^8.6.0",
    "hono": "^4.12.8",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "lucide-solid": "^0.577.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.9.3",
    "solid-js": "^1.9.11",
    "solid-sonner": "^0.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vinxi": "^0.5.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kobalte/tailwindcss": "^0.9.0",
    "drizzle-kit": "^1.0.0-beta.17-67b1795",
    "lefthook": "^2.1.4",
    "tw-animate-css": "^1.4.0"
  },
  "allowScripts": ["npm:lefthook"],
  "engines": {
    "node": ">=22"
  }
}
